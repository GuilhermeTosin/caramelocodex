{
  "routes": [
    { "src": "/sitemap.xml", "dest": "/api/sitemap-index" },
    { "src": "/sitemaps/static.xml", "dest": "/api/sitemap-static" },
    { "src": "/sitemaps/businesses-([^/]+)\\.xml", "dest": "/api/sitemap-businesses?page=$1" },

    {
      "src": "/$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb]ot|facebookexternalhit|[Ss]lack|[Ww]hats[Aa]pp|[Tt]elegram|ia_archiver).*"
        }
      ],
      "dest": "/api/ssr-static?page=home"
    },
    {
      "src": "/([^/]+)$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb]ot|facebookexternalhit|[Ss]lack|[Ww]hats[Aa]pp|[Tt]elegram|ia_archiver).*"
        }
      ],
      "dest": "/api/ssr-static?slug=$1"
    },

    {
      "src": "/eventos/([^/]+)$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb]ot|facebookexternalhit|[Ss]lack|[Ww]hats[Aa]pp|[Tt]elegram|ia_archiver).*"
        }
      ],
      "dest": "/api/ssr-dynamic?kind=event&eventId=$1"
    },
    {
      "src": "/go/([^/]+)$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb]ot|facebookexternalhit|[Ss]lack|[Ww]hats[Aa]pp|[Tt]elegram|ia_archiver).*"
        }
      ],
      "dest": "/api/ssr-dynamic?kind=go&businessSlug=$1"
    },
    {
      "src": "/([^/]+)/([^/]+)/([^/]+)/([^/]+)$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb]ot|facebookexternalhit|[Ss]lack|[Ww]hats[Aa]pp|[Tt]elegram|ia_archiver).*"
        }
      ],
      "dest": "/api/ssr-dynamic?kind=business&countryCode=$1&businessName=$4"
    },
    {
      "src": "/([^/]+)/([^/]+)$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb]ot|facebookexternalhit|[Ss]lack|[Ww]hats[Aa]pp|[Tt]elegram|ia_archiver).*"
        }
      ],
      "dest": "/api/ssr-dynamic?kind=business&countryCode=$1&businessName=$2"
    },

    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
